# Architecture enforcement (M0a) — the dependency-direction guard that makes the
# layer boundary real rather than aspirational. Run by CI (.github/workflows/
# layer-guard.yml) via `lint-imports`. Contracts start with the invariants that
# are TRUE today (so CI is green immediately) and broaden as legacy violations
# are fixed (the incremental M0b drain). Design of record: ROADMAP_MACRO.md.
#
# Layer model (nothing imports "up"):
#   Layer 1 Signals    — data/normalization/point-in-time stores/features/event calendars
#   Layer 2 Strategy   — signals -> TradeThesis/intents (no order path)
#   Layer 3 Execution  — order routing/brokers/fills/reconciliation/risk/kill-switches
#   Layer 0 Platform   — cross-cutting: config/db/logging/paths/web (any layer may use)
[importlinter]
root_package = src

[importlinter:contract:signals-strategy-no-execution]
# The macro/value thesis engine (Layer 1 Signals + Layer 2 Strategy) is the
# reference-clean island and the base the energy/carbon tenant reuses. Lock its
# purity in permanently — it must never reach the Execution layer, a broker
# adapter, or the order path — so it stays extractable/sellable on its own.
name = macro_thesis must not import Execution, brokers, or the order path
type = forbidden
source_modules =
    src.units.strategies.macro_thesis
forbidden_modules =
    src.units.accounts
    src.exchange
    src.core.order_contract
    src.runtime.order_monitor
    src.runtime.orders

[importlinter:contract:news-signals-no-execution]
# The M9 news layer is a Layer 1 Signals feed (external event/sentiment). It must
# not reach the order path — same purity as macro_thesis, so it can extract with it.
name = news (signals feed) must not import Execution, brokers, or the order path
type = forbidden
source_modules =
    src.news
forbidden_modules =
    src.units.accounts
    src.exchange
    src.core.order_contract
    src.runtime.order_monitor
    src.runtime.orders

[importlinter:contract:ict-detection-no-execution]
# The ICT pattern library (Layer 1 Signals — FVG/liquidity/order-blocks/sweeps)
# is pure feature detection. It must not reach strategy execution or the order path.
name = ict_detection (signals) must not import Execution, brokers, or the order path
type = forbidden
source_modules =
    src.ict_detection
forbidden_modules =
    src.units.accounts
    src.exchange
    src.core.order_contract
    src.runtime.order_monitor
    src.runtime.orders

[importlinter:contract:pairs-engine-no-execution]
# The M22 pairs sleeve splits cleanly: pairs_engine (the spread/z DECISION — pure
# Strategy) vs pairs_executor (the order router — Execution). pairs_executor
# legitimately imports the order path (it IS an executor); the invariant to lock
# is that the DECISION half stays pure. NB: the pairs sleeve is an INTENTIONAL
# isolated order path (CLAUDE.md — not via multi_account_execute), so
# pairs_executor is NOT routed through the coordinator seam; classifying it as
# Execution is the correct resolution, not a refactor of the live order path.
name = pairs_engine (strategy decision) must not import Execution, brokers, or the order path
type = forbidden
source_modules =
    src.units.strategies.pairs_engine
    src.units.strategies.pairs_sizing
forbidden_modules =
    src.units.accounts
    src.exchange
    src.core.order_contract
    src.runtime.order_monitor
    src.runtime.orders

[importlinter:contract:vwap-strategy-no-execution-impl]
# vwap is a Layer 2 STRATEGY (not a pure Signal feed). The distinction matters:
# a strategy legitimately references the ORDER-PACKAGE CONTRACT TYPE
# (src.core.order_contract, via _base's TYPE_CHECKING import) — that seam is how
# a strategy declares "I produce/monitor order packages" WITHOUT a runtime
# Execution dependency, so it is intentionally NOT forbidden here (unlike the
# pure Signal-feed contracts above, which forbid order_contract because a feed
# should not touch order types at all). What a strategy must NOT import is any
# Execution *implementation* — brokers, the risk sizer, the order monitor, the
# order path. Locking vwap became possible after the M0b drain cut the
# units.db.database -> runtime.local_pnl -> {risk, exchange} edge
# (BL-20260723-DB-LAYER-IMPURITY): vwap reaches the DB for reads, and the DB is
# now Execution-clean. This is the first monolith-era strategy locked; more
# follow as their transitive DB/runtime edges drain.
name = vwap strategy must not import Execution implementations (brokers/risk/order path)
type = forbidden
source_modules =
    src.units.strategies.vwap
forbidden_modules =
    src.units.accounts
    src.exchange
    src.runtime.order_monitor
    src.runtime.orders
