# =============================================================================
# ICT Trading Bot -- Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# This bot trades live on real exchange accounts. There is no paper-trading
# mode. Validate strategy ideas in backtests, then deploy live on a small
# account.
# =============================================================================

# -----------------------------------------------------------------------------
# Exchange Selection (required)
# Supported values: binance | bybit
# -----------------------------------------------------------------------------
EXCHANGE=bybit

# -----------------------------------------------------------------------------
# Exchange API Credentials
# Only the keys for your chosen EXCHANGE are required.
# Leave the other block empty or omit it entirely.
# -----------------------------------------------------------------------------

# -- Binance (required when EXCHANGE=binance) --
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# -- Bybit (required when EXCHANGE=bybit) --
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# -----------------------------------------------------------------------------
# Telegram Alerts (always required, regardless of exchange)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# Claude Telegram Bridge (optional -- only required for ict-claude-bridge.service)
# Token comes from a SECOND Telegram bot created via @BotFather (separate from
# the main TELEGRAM_BOT_TOKEN above; Telegram allows only one poller per token).
# Both names are managed by notebooks/operator/rotate_api_keys.ipynb.
# -----------------------------------------------------------------------------
TELEGRAM_CLAUDE_BOT_TOKEN=your_second_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-7

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------

# Market symbol as recognised by your exchange (e.g. BTCUSDT)
SYMBOL=BTCUSDT

# Candle timeframe (e.g. 1m, 5m, 15m, 1h, 4h, 1d).
#
# Per-strategy timeframes in config/strategies.yaml take precedence
# over this env var (S-015 mid-sprint fix). Set this only as a
# fallback for strategies that don't pin their own timeframe.
# Current per-strategy values:
#   vwap:        5m   (set in config/strategies.yaml)
#   turtle_soup: 15m  (set in config/strategies.yaml)
TIMEFRAME=5m

# Fraction of account balance to risk per trade (0 < value <= 1)
RISK_PER_TRADE=0.01

# Maximum position size in base-asset units (hard cap per order)
MAX_QTY=0.001

# -----------------------------------------------------------------------------
# Live-trading mode (operator directive 2026-05-03 — per BUG-039)
# The ONLY dry/live toggle is per-account `mode: live | dry_run` in
# config/accounts.yaml. DRY_RUN and ALLOW_LIVE_TRADING env vars are
# no longer read by the bot. Set mode: dry_run on an account entry to
# paper-trade that account; all other accounts remain live by default.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Runtime Settings
# -----------------------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Seconds between each strategy tick (900 = 15 minutes)
TICK_INTERVAL_SECONDS=900

# Set LOOP=true to run continuously; LOOP=false for a single tick then exit
LOOP=true

# Comms channel git writeback (S-027 comms handler).
# When 1, the bot pushes operator answers back to the repo automatically.
# Leave at 0 until the bot's git identity and SSH key are confirmed on the VM.
COMMS_PUSH_ENABLED=0

# Added for exchange environment control
BYBIT_TESTNET=false
BINANCE_TESTNET=false
TRADE_JOURNAL_DB=/home/ubuntu/ict-trading-bot/trade_journal.db

# -----------------------------------------------------------------------------
# Monitor-loop reconciler (BUG-042 PR 3/3)
# When true, every monitor tick compares DB-open trades against the exchange's
# live position snapshot; mismatches are marked status='orphaned' in the DB
# (no exchange writes). Default was false during the PR-2 soak window.
# Set to true once you've verified dry-run behaviour is stable on your VM.
# See docs/runbooks/monitor-reconciler.md for full operator guide.
# -----------------------------------------------------------------------------
MONITOR_RECONCILE_ENABLED=true

# -----------------------------------------------------------------------------
# News layer (M9) — default disabled
# The news-augmented decision layer is wired but inert until both flags are
# explicitly set. If either is absent the hook is a silent no-op.
# See docs/news_layer.md "Going live" section before enabling.
# -----------------------------------------------------------------------------
NEWS_ENABLED=false
# NEWS_API_KEY=           # NewsAPI key — uncomment and set to activate

# -----------------------------------------------------------------------------
# ICT Strategy Risk (S-006) — synthetic backtest: PF=2.04, 1048 trades → GO
# -----------------------------------------------------------------------------
ICT_RISK_PCT=0.4          # % of capital per ICT FVG+OB trade (0.4 = 0.4%)

# -----------------------------------------------------------------------------
# Web dashboard (S-013) — read-only API
# -----------------------------------------------------------------------------
# JWT signing key for HS256 tokens. Generate a fresh value on the VM:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never commit a real value. Only set on the VM via /etc/ict-trader/web-api.env.
JWT_SIGNING_KEY=

# Single-operator allowlist for /api/auth/login.
ALLOWED_EMAIL=

# SHA-256 hex of the operator's password. Generate with:
#   python -c "import hashlib,getpass; print(hashlib.sha256(getpass.getpass().encode()).hexdigest())"
# Never store the plaintext password anywhere.
WEBAPP_PASSWORD_SHA256=

# Public URL the /webapp Telegram command links to (set in S-013 M4 PR #2).
# Leave unset until the dashboard is reachable; the bot replies with a
# clean "not configured yet" message when this is empty.
WEBAPP_URL=
