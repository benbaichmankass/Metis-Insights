# =============================================================================
# ICT Trading Bot -- Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Exchange Selection (required)
# Supported values: binance | bybit
# -----------------------------------------------------------------------------
EXCHANGE=binance

# -----------------------------------------------------------------------------
# Exchange API Credentials
# Only the keys for your chosen EXCHANGE are required.
# Leave the other block empty or omit it entirely.
# -----------------------------------------------------------------------------

# -- Binance (required when EXCHANGE=binance) --
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# -- Bybit (required when EXCHANGE=bybit) --
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# -----------------------------------------------------------------------------
# Telegram Alerts (always required, regardless of exchange)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------

# Trading mode: LIVE | PAPER | BACKTEST
MODE=PAPER

# Market symbol as recognised by your exchange (e.g. BTCUSDT)
SYMBOL=BTCUSDT

# Candle timeframe (e.g. 1m, 5m, 15m, 1h, 4h, 1d)
TIMEFRAME=15m

# Fraction of account balance to risk per trade (0 < value <= 1)
RISK_PER_TRADE=0.01

# Maximum position size in base-asset units (hard cap per order)
MAX_QTY=0.001

# -----------------------------------------------------------------------------
# Live-Trading Safety Interlock
# DRY_RUN=false + ALLOW_LIVE_TRADING=true => real orders will be placed.
# Any other combination is paper/simulation only.
# -----------------------------------------------------------------------------
DRY_RUN=true
ALLOW_LIVE_TRADING=false

# -----------------------------------------------------------------------------
# Runtime Settings
# -----------------------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Seconds between each strategy tick (900 = 15 minutes)
TICK_INTERVAL_SECONDS=900

# Set LOOP=true to run continuously; LOOP=false for a single tick then exit
LOOP=true

# Added for exchange environment control
BYBIT_TESTNET=false
BINANCE_TESTNET=false
TRADE_JOURNAL_DB=/home/ubuntu/ict-trading-bot/trade_journal.db
