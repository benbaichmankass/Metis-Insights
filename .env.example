# ── Bot / Exchange ──────────────────────────────────────────────
BYBIT_API_KEY=your_api_key
BYBIT_API_SECRET=your_api_secret
BYBIT_TESTNET=false

# ── Interactive Brokers (TWS API via ib_insync) ─────────────────
# IB uses NO API keys — authentication is the IB Gateway / TWS login
# session. These OPTIONAL vars only override the per-account ib_* fields
# in config/accounts.yaml (ib_host / ib_port / ib_account / ib_client_id).
# Leave unset to use the values committed in accounts.yaml. Host defaults
# to 127.0.0.1. Live gateway port is 7496, paper is 7497.
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_ACCOUNT=
# IB_CLIENT_ID=

# ── Database ────────────────────────────────────────────────────
TRADE_JOURNAL_DB=trade_journal.db

# ── Dashboard API (S-014) ────────────────────────────────────────
# Public URL of the Vercel dashboard (enables CORS on the FastAPI).
# Also set directly in deploy/ict-web-api.service for autosync.
DASHBOARD_ORIGIN=https://bentzbk-ict-trader-dashboard.vercel.app

# Bearer token checked by /api/auth/* routes (leave empty to disable)
DASHBOARD_API_TOKEN=

# ── Web API ─────────────────────────────────────────────────────
WEB_API_PORT=8001

# ── Notifications ───────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Runtime data roots (OCI block-storage externalization) ──────
# All four are OPTIONAL. Unset → behavior unchanged (repo-relative
# `runtime_logs/`, `runtime_state/`, `data/`, `artifacts/`).
#
# Production migration: set DATA_DIR to the mounted OCI block volume
# (e.g. /data/bot-data) and rsync the repo subdirs there once. The
# helper resolves to <DATA_DIR>/<subdir> for each logical root.
#
# Per-root overrides (RUNTIME_LOGS_DIR etc.) win over DATA_DIR, useful
# for splitting hot logs onto a different volume than cold artifacts.
# See docs/architecture/oci-block-storage.md for the migration contract.
DATA_DIR=
# RUNTIME_LOGS_DIR=
# RUNTIME_STATE_DIR=
# ARTIFACTS_DIR=
