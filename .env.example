# ── Bot / Exchange ──────────────────────────────────────────────
BYBIT_API_KEY=your_api_key
BYBIT_API_SECRET=your_api_secret
BYBIT_TESTNET=false

# ── Database ────────────────────────────────────────────────────
TRADE_JOURNAL_DB=trade_journal.db

# ── Dashboard API (S-014) ────────────────────────────────────────
# Public URL of the Vercel dashboard (enables CORS on the FastAPI).
# This is also set directly in deploy/ict-web-api.service so autosync
# picks it up; only override here if you need a different value.
DASHBOARD_ORIGIN=https://bentzbk-ict-trader-dashboard.vercel.app

# Bearer token checked by /api/auth/* routes (leave empty to disable auth)
DASHBOARD_API_TOKEN=

# ── Web API ─────────────────────────────────────────────────────
# Port the FastAPI is bound to (systemd service default: 8001)
WEB_API_PORT=8001

# ── Notifications ───────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
