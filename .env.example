# Bybit credentials (currently still required by startup validation in some flows)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true
BYBIT_SYMBOL=BTCUSDC

# Binance credentials (used when EXCHANGE=binance)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# App settings
LOG_LEVEL=INFO

# Runtime settings
EXCHANGE=bybit
MODE=testnet
SYMBOL=BTCUSDT
TIMEFRAME=15
RISK_PER_TRADE=0.01
MAX_QTY=10
DRY_RUN=true
ALLOW_LIVE_TRADING=false
