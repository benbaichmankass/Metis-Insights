# Bybit
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true
BYBIT_SYMBOL=BTCUSDC

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
