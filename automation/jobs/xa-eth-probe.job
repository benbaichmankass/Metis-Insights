TARGET=trainer
---
set -uo pipefail
BR=claude/ict-strategy-expansion-awpv8x
REPO=/home/ubuntu/ict-trading-bot
WT=/tmp/xa-probe
echo "===== sync branch into a throwaway worktree ====="
cd "$REPO" || exit 2
git fetch origin "$BR" || exit 2
git worktree remove --force "$WT" 2>/dev/null || true
rm -rf "$WT"
git worktree add -f "$WT" "origin/$BR" || exit 2
cd "$WT" || exit 2
git log --oneline -1
# shellcheck disable=SC1091
source "$REPO/.venv/bin/activate"
export ICT_OFFVM_BUILD_HOST=1
python -c "import ccxt" 2>/dev/null || pip install --quiet "ccxt>=4.0" || true

OUT="$WT/datasets-out"
REG="$WT/ml/registry-store"
EXP="$WT/ml/experiments-runs"
START="$(date -u -d '5 years ago' +%Y-%m-%d 2>/dev/null || echo 2021-01-01)"
END="$(date -u +%Y-%m-%d)"
echo "window $START -> $END"

echo "===== 1. market_raw ETH/BTC/SOL 1h ====="
for S in ETHUSDT BTCUSDT SOLUSDT; do
  echo "--- market_raw $S ---"
  python -m ml build-dataset market_raw --output-dir "$OUT" --version v002 \
    --source bybit_v5_offvm --symbol-scope "$S" --timeframe 1h --overwrite \
    "adapter=bybit_v5_offvm" "symbol=$S" "timeframe=1h" "start=$START" "end=$END" \
    || echo "WARN: market_raw $S failed"
  wc -l "$OUT/market_raw/$S/1h/v002/data.jsonl" 2>/dev/null || true
done

echo "===== 2. cross_asset side-stream (ETH <- BTC, SOL) ====="
python -m scripts.ml.build_cross_asset \
  --target "$OUT/market_raw/ETHUSDT/1h/v002" \
  --peer "$OUT/market_raw/BTCUSDT/1h/v002" \
  --peer "$OUT/market_raw/SOLUSDT/1h/v002" \
  --out "$OUT/cross_asset/ETHUSDT/1h/v001" || { echo "FATAL: side-stream build failed"; exit 1; }

echo "===== 3. market_features ETH 1h WITH cross_asset ====="
python -m ml build-dataset market_features --output-dir "$OUT" --version v001 \
  --source "$OUT/market_raw/ETHUSDT/1h/v002" --symbol-scope ETHUSDT --timeframe 1h \
  --overwrite "market_raw_path=$OUT/market_raw/ETHUSDT/1h/v002" \
  "cross_asset_path=$OUT/cross_asset/ETHUSDT/1h/v001" \
  "vol_window_n=20" "forward_window_m=5" "vol_threshold=0.005" \
  "trend_threshold=0.005" "n_vol_buckets=3" || { echo "FATAL: market_features build failed"; exit 1; }
echo "--- verify xa columns populated in the built dataset ---"
head -1 "$OUT/market_features/ETHUSDT/1h/v001/data.jsonl" | python -c "
import sys,json
r=json.loads(sys.stdin.read())
xa={k:r[k] for k in r if k.startswith('xa_')}
print('xa cols present:', len(xa))
print('sample:', {k:xa[k] for k in list(xa)[:5]})
"
python -c "
import json
p='$OUT/market_features/ETHUSDT/1h/v001/data.jsonl'
n=0; nz=0
for line in open(p):
    n+=1
    r=json.loads(line)
    if any(abs(r[k])>0 for k in r if k.startswith('xa_')): nz+=1
print(f'rows={n} rows_with_nonzero_xa={nz}')
"

echo "===== 4. train both legs ====="
for M in eth-regime-1h-lgbm-v1 eth-regime-1h-lgbm-xasset-v1; do
  echo "--- train $M ---"
  python -m ml train "ml/configs/$M.yaml" \
    --datasets-root "$OUT" --registry-root "$REG" --experiments-root "$EXP" \
    --commit-sha "$(git rev-parse --short HEAD)" || echo "WARN: train $M failed"
done

echo "===== 5. A/B compare (delta = xasset - base) ====="
python -m ml compare eth-regime-1h-lgbm-v1 eth-regime-1h-lgbm-xasset-v1 \
  --registry-root "$REG" || echo "WARN: compare failed"

echo "===== done ====="
