TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot
git fetch origin main -q; git checkout -f main -q 2>/dev/null; git reset --hard origin/main -q
source .venv/bin/activate 2>/dev/null || source venv/bin/activate 2>/dev/null || true
R=results/m15_adx_holdout; mkdir -p "$R"; WF_END="2026-06-11"
ds(){ head -2 "$1" | tail -1 | cut -d, -f1 | cut -dT -f1 | cut -d' ' -f1; }
emit(){ local fam=$1 sym=$2 adx=$3 scr=$4 rs=$5 D="data/$2_15m.csv"
  [ -f "$R/${fam}_${sym}_a${adx}_f7.5.jsonl" ] && return 0
  for FEE in 7.5 15.0; do python3 "scripts/$scr" --data "$D" --resample "$rs" --timeframe "$rs" --symbol "$sym" --adx-min "$adx" --fee-bps-roundtrip "$FEE" --emit-trades "$R/${fam}_${sym}_a${adx}_f${FEE}.jsonl" --json /dev/null >/dev/null 2>&1; done; }
foldrep(){ python3 scripts/ops/m15_ws_b_fold_report.py --mode net --emit "$R/$1_$2_a$3_f7.5.jsonl" --emit-2x "$R/$1_$2_a$3_f15.0.jsonl" --fee-bps 7.5 --wf-start "$6" --wf-end "$WF_END" --folds "$4" --train-frac "$5" --label "$1_$2_a$3_k$4_t$5" --json "$R/fold_$1_$2_a$3_k$4_t$5.json" >/dev/null 2>&1; }
C=( "pullback ETHUSDT 25 backtest_pullback.py 2h" "pullback ADAUSDT 30 backtest_pullback.py 2h" "pullback SOLUSDT 15 backtest_pullback.py 2h" "trend XRPUSDT 15 backtest_trend.py 4h" )
for c in "${C[@]}"; do
  set -- $c; fam=$1; sym=$2; tuned=$3; scr=$4; rs=$5; WS=$(ds "data/${sym}_15m.csv")
  for adx in $((tuned-2)) $((tuned-1)) $tuned $((tuned+1)) $((tuned+2)); do
    [ "$adx" -lt 5 ] && continue; emit "$fam" "$sym" "$adx" "$scr" "$rs"; foldrep "$fam" "$sym" "$adx" 5 0.4 "$WS"
  done
  for k in 6 7; do foldrep "$fam" "$sym" "$tuned" "$k" 0.4 "$WS"; done
  for tf in 0.35 0.45; do foldrep "$fam" "$sym" "$tuned" 5 "$tf" "$WS"; done
done
echo "=== HOLDOUT VERDICT per candidate ==="
python3 - <<'PY'
import json,glob,os,re
cands={("pullback","ETHUSDT"):25,("pullback","ADAUSDT"):30,("pullback","SOLUSDT"):15,("trend","XRPUSDT"):15}
def load(f):
    try: d=json.load(open(f)); return (d['gate_all_folds_positive'], round(d['total_oos_net_r_base'],1))
    except: return None
for (fam,sym),tuned in cands.items():
    # plateau: tuned-2..tuned+2 at k5 t0.4
    band=[]
    for adx in range(tuned-2,tuned+3):
        r=load(f"results/m15_adx_holdout/fold_{fam}_{sym}_a{adx}_k5_t0.4.json")
        if r: band.append((adx,r[0],r[1]))
    plateau=sum(1 for a,p,n in band if p)
    # fold-config: tuned at k5/6/7 t0.4 + k5 t0.35/0.45
    cfgs=[]
    for tag in [f"a{tuned}_k5_t0.4",f"a{tuned}_k6_t0.4",f"a{tuned}_k7_t0.4",f"a{tuned}_k5_t0.35",f"a{tuned}_k5_t0.45"]:
        r=load(f"results/m15_adx_holdout/fold_{fam}_{sym}_{tag}.json")
        if r: cfgs.append((tag,r[0]))
    cfg_pass=sum(1 for t,p in cfgs if p)
    robust = plateau>=3 and cfg_pass==len(cfgs) and len(cfgs)>=4
    print(f"\n{fam}_{sym} @ADX{tuned}: {'ROBUST ✅' if robust else 'FRAGILE ⚠'}")
    print("  threshold band:", " ".join(f"a{a}:{'P' if p else 'f'}({n})" for a,p,n in band), f"-> {plateau}/5 pass")
    print("  fold configs:  ", " ".join(f"{t.split('_',1)[1]}:{'P' if p else 'f'}" for t,p in cfgs), f"-> {cfg_pass}/{len(cfgs)} pass")
PY
echo "ADX_HOLDOUT_DONE"
