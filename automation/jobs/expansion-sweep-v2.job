TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot || { echo "NO REPO"; exit 1; }
BR=claude/expansion-backtesting-research-y74054
git fetch -q origin "$BR" 2>&1 | tail -1 || true
mkdir -p /tmp/studies
for s in trend_oop_holdout pullback_exit_feebleed; do
  git show "origin/$BR:config/research/studies/$s.yaml" > /tmp/studies/$s.yaml 2>/dev/null && echo "got $s" || echo "MISSING $s"
done
sed -e 's/BNBUSDT/LINKUSDT/g' -e 's/trend_oop_holdout_bnb/trend_oop_holdout_link/' \
    /tmp/studies/trend_oop_holdout.yaml > /tmp/studies/trend_oop_holdout_link.yaml

# Locate a python that actually has pandas (the trainer's venv) — bare python3 lacks it.
PYBIN=""
for c in .venv/bin/python venv/bin/python ./env/bin/python /opt/ict-trading-bot/.venv/bin/python \
         $(find /home/ubuntu -maxdepth 5 -path '*/bin/python' 2>/dev/null); do
  if [ -x "$c" ] && "$c" -c "import pandas" 2>/dev/null; then PYBIN="$c"; break; fi
done
if [ -z "$PYBIN" ]; then
  echo "NO pandas-capable python found. Diagnostics:"
  which python3 2>&1; python3 -c "import sys;print(sys.executable)" 2>&1
  systemctl cat ict-trainer.service 2>/dev/null | grep -iE "ExecStart|WorkingDirectory|EnvironmentFile" | head
  find /home/ubuntu -maxdepth 5 -path '*/bin/activate' 2>/dev/null | head
  exit 0
fi
echo "USING PYBIN=$PYBIN"
"$PYBIN" -c "import pandas,sys;print('pandas',pandas.__version__,'py',sys.version.split()[0])"

for s in trend_oop_holdout trend_oop_holdout_link pullback_exit_feebleed; do
  echo ""
  echo "######################## RUN $s ########################"
  timeout 2400 "$PYBIN" scripts/ops/research_sweep.py --study /tmp/studies/$s.yaml --out /tmp/out_$s 2>&1 | tail -70
done
echo "== ALL DONE =="
