TARGET=trainer
---
set +e
R=/home/ubuntu/ict-trading-bot
cd "$R" || { echo "NO REPO"; exit 1; }
echo "HEAD=$(git rev-parse --short HEAD) branch=$(git rev-parse --abbrev-ref HEAD)"
# Ensure the yfinance adapter + MES manifests are present. Only checkout if
# missing, so a running serious-baseline isn't disrupted mid-flight.
if [ ! -f ml/configs/mes-regime-5m.yaml ]; then
  git fetch -q origin claude/mes-training-dashboard-tabs-zDNzM \
    && git checkout -q origin/claude/mes-training-dashboard-tabs-zDNzM -- ml/ scripts/ops/ 2>/dev/null || true
fi
source .venv/bin/activate 2>/dev/null || { echo "no venv"; exit 1; }
python -c "import yfinance" 2>/dev/null || pip install -q "yfinance>=0.2"
export ICT_OFFVM_BUILD_HOST=1
START=$(date -u -d '58 days ago' +%Y-%m-%d)
END=$(date -u +%Y-%m-%d)
echo "MES yfinance (ES=F) window: $START -> $END"
for tf in 5m 15m; do
  case $tf in 5m) VT=0.0008;; 15m) VT=0.0012;; esac
  echo "=== market_raw MES $tf ==="
  python -m ml build-dataset market_raw --output-dir datasets-out --version v001 \
    --source yfinance_offvm --symbol-scope MES --timeframe $tf --overwrite \
    adapter=yfinance_offvm symbol=MES timeframe=$tf start=$START end=$END 2>&1 | tail -3
  RAW=datasets-out/market_raw/MES/$tf/v001
  python -c "import json;print('  raw rows:',json.load(open('$RAW/metadata.json'))['row_count'])" 2>/dev/null || echo "  (no raw meta)"
  echo "=== market_features MES $tf ==="
  python -m ml build-dataset market_features --output-dir datasets-out --version v001 \
    --source $RAW --symbol-scope MES --timeframe $tf --overwrite \
    market_raw_path=$RAW vol_window_n=20 forward_window_m=5 vol_threshold=$VT trend_threshold=$VT n_vol_buckets=3 2>&1 | tail -3
  echo "=== train mes-regime-$tf ==="
  python -m ml train ml/configs/mes-regime-$tf.yaml --datasets-root datasets-out \
    --experiments-root ml/experiments-runs --registry-root ml/registry-store 2>&1 | tail -6
done
echo "=== MES regime models in registry ==="
python -m ml list-models --registry-root ml/registry-store 2>/dev/null | python -c "import sys,json;d=json.load(sys.stdin);[print(' -',e['model_id'],e.get('metrics')) for e in d if 'mes-regime' in (e.get('model_id') or '')]" 2>/dev/null || echo "(list failed)"
echo "=== BTC serious-baseline status (tail) ==="
tail -n 14 runtime_logs/trainer/serious_baseline.jsonl 2>/dev/null || echo "(no btc baseline log)"
