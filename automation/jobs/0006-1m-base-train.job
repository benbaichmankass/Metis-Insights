TARGET=trainer
---
set +e
R=/home/ubuntu/ict-trading-bot
cd "$R" || exit 1
if pgrep -f run_serious_baseline.sh >/dev/null 2>&1; then echo "ALREADY RUNNING pid=$(pgrep -f run_serious_baseline.sh)"; exit 0; fi
git fetch -q origin claude/mes-training-dashboard-tabs-zDNzM && git checkout -f -q -B claude/mes-training-dashboard-tabs-zDNzM origin/claude/mes-training-dashboard-tabs-zDNzM
echo "HEAD=$(git rev-parse --short HEAD)"
mkdir -p runtime_logs/trainer
# 1m base for all training: pull 1m once (BTC via Bybit; MES via yfinance falls back to 5m base),
# derive 5m/15m by resample, train regime per TF. Backtests skipped for speed (BACKTEST=0).
setsid env BASE_TF=1m BACKTEST=0 bash scripts/ops/run_serious_baseline.sh > runtime_logs/trainer/serious_baseline.out 2>&1 < /dev/null &
echo "launched 1m-base run pid=$! at $(date -u +%FT%TZ)"
sleep 12
echo "=== early log ==="
tail -n 10 runtime_logs/trainer/serious_baseline.jsonl 2>/dev/null || echo "(pending)"
