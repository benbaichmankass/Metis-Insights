TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot
git fetch origin main -q; git checkout -f main -q 2>/dev/null; git reset --hard origin/main -q
git fetch origin claude/system-audit-strategy-ml-srcwda -q
git checkout origin/claude/system-audit-strategy-ml-srcwda -- scripts/ops/regime_performance_map.py scripts/ops/regime_weight_overlay.py
source .venv/bin/activate 2>/dev/null || source venv/bin/activate 2>/dev/null || true
R=results/m15_regime_map; mkdir -p "$R"
emit(){ local fam=$1 scr=$2 rs=$3 sym=$4 D="data/$4_15m.csv"; [ -f "$D" ] || return
  [ -s "$R/${fam}_${sym}.jsonl" ] && return 0
  python3 "scripts/$scr" --data "$D" --resample "$rs" --timeframe "$rs" --symbol "$sym" --emit-trades "$R/${fam}_${sym}.jsonl" --json /dev/null >/dev/null 2>&1; }
for SYM in ETHUSDT SOLUSDT XRPUSDT ADAUSDT AVAXUSDT; do emit trend backtest_trend.py 4h "$SYM"; emit pullback backtest_pullback.py 2h "$SYM"; done
# manifest of the 10 cells
python3 - <<'PY'
import json
m=[]
for sym in ["ETHUSDT","SOLUSDT","XRPUSDT","ADAUSDT","AVAXUSDT"]:
    m.append({"label":f"trend_{sym}","data":f"data/{sym}_15m.csv","resample":"4h","emit":f"results/m15_regime_map/trend_{sym}.jsonl"})
    m.append({"label":f"pullback_{sym}","data":f"data/{sym}_15m.csv","resample":"2h","emit":f"results/m15_regime_map/pullback_{sym}.jsonl"})
json.dump(m,open("results/m15_regime_map/manifest.json","w"))
print("manifest:",len(m),"cells")
PY
for CUT in 2025-01-01 2024-07-01; do
  echo ""; echo "########## CUTOFF $CUT ##########"
  python3 scripts/ops/regime_weight_overlay.py --manifest results/m15_regime_map/manifest.json --cutoff "$CUT" --min-n 20 --json "$R/overlay_${CUT}.json"
done
echo "REGIME_OVERLAY_DONE"
