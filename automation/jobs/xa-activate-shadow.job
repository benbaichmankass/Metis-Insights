TARGET=trainer
---
set -uo pipefail
REPO=/home/ubuntu/ict-trading-bot
echo "===== sync trainer repo to merged main ====="
cd "$REPO" || exit 2
git fetch origin main || exit 2
git reset --hard origin/main || exit 2
git log --oneline -1
# shellcheck disable=SC1091
source "$REPO/.venv/bin/activate"
export ICT_OFFVM_BUILD_HOST=1
OUT="$REPO/datasets-out"
REG="$REPO/ml/registry-store"
EXP="$REPO/ml/experiments-runs"
START="$(date -u -d '5 years ago' +%Y-%m-%d 2>/dev/null || echo 2021-01-01)"
END="$(date -u +%Y-%m-%d)"
python -c "import ccxt" 2>/dev/null || pip install --quiet "ccxt>=4.0" || true

echo "===== 1. market_raw ETH/BTC/SOL 1h -> production datasets-out ====="
for S in ETHUSDT BTCUSDT SOLUSDT; do
  python -m ml build-dataset market_raw --output-dir "$OUT" --version v002 \
    --source bybit_v5_offvm --symbol-scope "$S" --timeframe 1h --overwrite \
    "adapter=bybit_v5_offvm" "symbol=$S" "timeframe=1h" "start=$START" "end=$END" \
    && wc -l "$OUT/market_raw/$S/1h/v002/data.jsonl" || echo "WARN market_raw $S"
done

echo "===== 2. cross_asset side-stream + 3. market_features ETH 1h v001 ====="
python -m scripts.ml.build_cross_asset \
  --target "$OUT/market_raw/ETHUSDT/1h/v002" \
  --peer "$OUT/market_raw/BTCUSDT/1h/v002" --peer "$OUT/market_raw/SOLUSDT/1h/v002" \
  --out "$OUT/cross_asset/ETHUSDT/1h/v001" || { echo FATAL side-stream; exit 1; }
python -m ml build-dataset market_features --output-dir "$OUT" --version v001 \
  --source "$OUT/market_raw/ETHUSDT/1h/v002" --symbol-scope ETHUSDT --timeframe 1h \
  --overwrite "market_raw_path=$OUT/market_raw/ETHUSDT/1h/v002" \
  "cross_asset_path=$OUT/cross_asset/ETHUSDT/1h/v001" \
  "vol_window_n=20" "forward_window_m=5" "vol_threshold=0.005" \
  "trend_threshold=0.005" "n_vol_buckets=3" || { echo FATAL market_features; exit 1; }

echo "===== 4. train + register eth-regime-1h-lgbm-xasset-v1 (candidate) ====="
python -m ml train ml/configs/eth-regime-1h-lgbm-xasset-v1.yaml \
  --datasets-root "$OUT" --registry-root "$REG" --experiments-root "$EXP" \
  --commit-sha "$(git rev-parse --short HEAD)" || { echo FATAL train; exit 1; }

echo "===== 5. promote candidate -> shadow (autonomous; observe-only) ====="
python -m ml promote-stage eth-regime-1h-lgbm-xasset-v1 --new-stage shadow \
  --registry-root "$REG" --by claude \
  --reason "S-CROSS-ASSET-PROBE D2a: activate observe-only cross-asset regime soak (operator-approved 2026-06-18)" \
  || { echo FATAL promote; exit 1; }

echo "===== 6. publish trainer mirror -> live VM ====="
if [ -x scripts/ops/publish_trainer_mirror.sh ]; then
  scripts/ops/publish_trainer_mirror.sh 2>&1 | tail -20 || echo "WARN publish_trainer_mirror rc=$?"
else
  bash scripts/ops/publish_trainer_mirror.sh 2>&1 | tail -20 || echo "WARN publish rc=$?"
fi

echo "===== 7. verify registry state ====="
python -m ml list-models --registry-root "$REG" 2>/dev/null | grep -i "eth-regime-1h-lgbm-xasset\|stage\|shadow" | head -20
echo "===== done ====="
