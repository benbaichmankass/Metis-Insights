TARGET=trainer
---
set -uo pipefail
BR=claude/ict-strategy-expansion-awpv8x
REPO=/home/ubuntu/ict-trading-bot
WT=/tmp/xa-dir
DATA=/tmp/xa-data
echo "===== sync branch into a throwaway worktree ====="
cd "$REPO" || exit 2
git fetch origin "$BR" || exit 2
git worktree remove --force "$WT" 2>/dev/null || true
rm -rf "$WT"
git worktree add -f "$WT" "origin/$BR" || exit 2
cd "$WT" || exit 2
git log --oneline -1
# shellcheck disable=SC1091
source "$REPO/.venv/bin/activate"
export ICT_OFFVM_BUILD_HOST=1
OUT="$DATA/datasets-out"
REG="$WT/ml/registry-store"
EXP="$WT/ml/experiments-runs"
START="$(date -u -d '5 years ago' +%Y-%m-%d 2>/dev/null || echo 2021-01-01)"
END="$(date -u +%Y-%m-%d)"

# market_raw + cross_asset side-stream are unchanged — reuse if cached.
if [ ! -f "$OUT/market_raw/ETHUSDT/1h/v002/data.jsonl" ]; then
  echo "===== rebuilding market_raw + side-stream ====="
  python -c "import ccxt" 2>/dev/null || pip install --quiet "ccxt>=4.0" || true
  for S in ETHUSDT BTCUSDT SOLUSDT; do
    python -m ml build-dataset market_raw --output-dir "$OUT" --version v002 \
      --source bybit_v5_offvm --symbol-scope "$S" --timeframe 1h --overwrite \
      "adapter=bybit_v5_offvm" "symbol=$S" "timeframe=1h" "start=$START" "end=$END" || echo "WARN $S"
  done
  python -m scripts.ml.build_cross_asset \
    --target "$OUT/market_raw/ETHUSDT/1h/v002" \
    --peer "$OUT/market_raw/BTCUSDT/1h/v002" --peer "$OUT/market_raw/SOLUSDT/1h/v002" \
    --out "$OUT/cross_asset/ETHUSDT/1h/v001" || exit 1
fi

echo "===== rebuild market_features at v9 (adds direction_label) ====="
python -m ml build-dataset market_features --output-dir "$OUT" --version v001 \
  --source "$OUT/market_raw/ETHUSDT/1h/v002" --symbol-scope ETHUSDT --timeframe 1h \
  --overwrite "market_raw_path=$OUT/market_raw/ETHUSDT/1h/v002" \
  "cross_asset_path=$OUT/cross_asset/ETHUSDT/1h/v001" \
  "vol_window_n=20" "forward_window_m=5" "vol_threshold=0.005" \
  "trend_threshold=0.005" "n_vol_buckets=3" || { echo FATAL build; exit 1; }
echo "--- direction_label class balance ---"
python -c "
import json,collections
c=collections.Counter(json.loads(l)['direction_label'] for l in open('$OUT/market_features/ETHUSDT/1h/v001/data.jsonl'))
print(dict(c))
"

echo "===== generate direction manifests (purged-WF-CV) + a lean variant ====="
python - <<'PY'
import yaml, pathlib, copy
base = yaml.safe_load(pathlib.Path("ml/configs/eth-direction-1h-lgbm-xasset-v1.yaml").read_text())
own = ["vol_bucket","rolling_log_return_vol","log_return","log_return_lag_1",
       "log_return_lag_2","hour_of_day","dayofweek"]
full_xa = base["trainer_config"]["feature_columns"][7:]
# lean = ablation-informed: SOL peer block + rel_strength(BTC) + breadth, drop lead-lag
lean_xa = ["xa_peer2_ret","xa_peer2_vol","xa_peer2_rel_strength","xa_peer2_beta",
           "xa_peer2_beta_residual","xa_peer1_rel_strength","xa_peer1_beta",
           "xa_peer1_beta_residual","xa_breadth_up"]
def patch(ec):
    ec.pop("holdout_fraction", None)
    ec.update(split_strategy="purged_walk_forward", time_column="ts",
              n_folds=5, min_train_fraction=0.5, embargo_n=10)
# base (own only)
mb = copy.deepcopy(base); mb["model_id"]="eth-dir-base"
mb["trainer_config"]["feature_columns"]=own; patch(mb["evaluator_config"])
pathlib.Path("ml/configs/eth-dir-base.yaml").write_text(yaml.safe_dump(mb,sort_keys=False))
# full xasset
mf = copy.deepcopy(base); mf["model_id"]="eth-dir-xasset"
mf["trainer_config"]["feature_columns"]=own+full_xa; patch(mf["evaluator_config"])
pathlib.Path("ml/configs/eth-dir-xasset.yaml").write_text(yaml.safe_dump(mf,sort_keys=False))
# lean xasset
ml_=copy.deepcopy(base); ml_["model_id"]="eth-dir-lean"
ml_["trainer_config"]["feature_columns"]=own+lean_xa; patch(ml_["evaluator_config"])
pathlib.Path("ml/configs/eth-dir-lean.yaml").write_text(yaml.safe_dump(ml_,sort_keys=False))
print("wrote base(own)/xasset(full)/lean(SOL+relstr+beta)")
PY

echo "===== train all three under purged-WF-CV ====="
for name in eth-dir-base eth-dir-xasset eth-dir-lean; do
  echo "--- $name ---"
  python -m ml train "ml/configs/$name.yaml" \
    --datasets-root "$OUT" --registry-root "$REG" --experiments-root "$EXP" \
    --commit-sha "$(git rev-parse --short HEAD)" 2>/dev/null | \
    python -c "import sys,json; d=json.load(sys.stdin); m=d['metrics']; ks=sorted(m); print('  '+' '.join(f'{k}={m[k]:.4f}' for k in ks if k in ('accuracy','macro_f1','weighted_f1','f1_up','f1_down','precision_up','recall_up','precision_down','recall_down','n_eval','n_folds')))" || echo "WARN $name"
done

echo "===== compare base vs xasset (delta = xasset - base) ====="
python -m ml compare eth-dir-base eth-dir-xasset --registry-root "$REG" 2>/dev/null \
  | python -c "import sys,json; d=json.load(sys.stdin); [print(f\"  {x['metric']:16} base={x['a']:.4f} xa={x['b']:.4f} delta={x['delta']:+.4f}\") for x in d['metric_diffs']]" || echo "WARN compare"
echo "===== done ====="
