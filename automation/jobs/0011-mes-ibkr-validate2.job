TARGET=live
---
set +e
LR=/home/ubuntu/ict-trading-bot
S=/tmp/ict-mes-pull
git -C "$LR" fetch -q origin claude/mes-training-dashboard-tabs-zDNzM 2>&1 | tail -1
git -C "$LR" worktree remove --force "$S" 2>/dev/null
git -C "$LR" worktree add -f "$S" origin/claude/mes-training-dashboard-tabs-zDNzM 2>&1 | tail -1
cd "$S" || { echo "no scratch"; exit 1; }
echo "HEAD=$(git rev-parse --short HEAD)"
echo "=== detect python with ib_insync ==="
PY=""
for c in "$LR/.venv/bin/python" "$LR/.venv/bin/python3" "$LR/venv/bin/python" "$LR/venv/bin/python3" /opt/ict-trading-bot/.venv/bin/python "$(command -v python3)"; do
  if [ -x "$c" ] && "$c" -c "import ib_insync, pandas, yaml" 2>/dev/null; then PY="$c"; break; fi
done
echo "PY=$PY"
[ -z "$PY" ] && { echo "no python with ib_insync found; candidates:"; ls -1 "$LR"/.venv/bin/ "$LR"/venv/bin/ 2>/dev/null | head; exit 1; }
"$PY" -c "import ib_insync;print('ib_insync',ib_insync.__version__)"
export ICT_IB_HISTORICAL_OK=1
START=$(date -u -d '5 days ago' +%Y-%m-%d 2>/dev/null || echo 2026-05-17)
echo "=== MES 1m VALIDATION pull ($START -> now) clientId=450 pause=12s ==="
timeout 300 "$PY" -m ml build-dataset market_raw --output-dir "$S/datasets-out" --version v001 \
  --source ibkr_offvm --symbol-scope MES --timeframe 1m --overwrite \
  adapter=ibkr_offvm symbol=MES start="$START" host=127.0.0.1 port=4002 client_id=450 pause_s=12 2>&1 | tail -12
echo "=== rows ==="
"$PY" -c "import json;print('MES 1m rows', json.load(open('$S/datasets-out/market_raw/MES/1m/v001/metadata.json'))['row_count'])" 2>/dev/null || echo "(no metadata — empty/failed)"
echo "=== sample bars ==="; head -c 400 "$S/datasets-out/market_raw/MES/1m/v001/data.jsonl" 2>/dev/null; echo
echo "=== live trader last 4 lines ==="; journalctl -u ict-trader-live.service -n 4 --no-pager 2>/dev/null | sed 's/.*python3\[[0-9]*\]: //' | tail -4
git -C "$LR" worktree remove --force "$S" 2>/dev/null
