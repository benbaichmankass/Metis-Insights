TARGET=live
---
set +e
LR=/home/ubuntu/ict-trading-bot
S=/tmp/ict-mes-pull
git -C "$LR" fetch -q origin claude/mes-training-dashboard-tabs-zDNzM 2>&1 | tail -1
git -C "$LR" worktree remove --force "$S" 2>/dev/null
git -C "$LR" worktree add -f "$S" origin/claude/mes-training-dashboard-tabs-zDNzM 2>&1 | tail -1
cd "$S" || exit 1
echo "HEAD=$(git rev-parse --short HEAD)"
PY=""; for c in "$LR/.venv/bin/python" /usr/bin/python3 "$(command -v python3)"; do [ -x "$c" ] && "$c" -c "import ib_insync,pandas,yaml" 2>/dev/null && { PY="$c"; break; }; done
echo "PY=$PY"
export ICT_IB_HISTORICAL_OK=1
START=$(date -u -d '5 days ago' +%Y-%m-%d 2>/dev/null || echo 2026-05-17)
echo "=== MES 1m validation ($START -> now), front-month dated contract, clientId=450 ==="
timeout 300 "$PY" -m ml build-dataset market_raw --output-dir "$S/datasets-out" --version v001 \
  --source ibkr_offvm --symbol-scope MES --timeframe 1m --overwrite \
  adapter=ibkr_offvm symbol=MES start="$START" host=127.0.0.1 port=4002 client_id=450 pause_s=8 max_contracts=1 2>&1 | tail -12
echo "=== rows ==="; "$PY" -c "import json;print('MES 1m rows', json.load(open('$S/datasets-out/market_raw/MES/1m/v001/metadata.json'))['row_count'])" 2>/dev/null || echo "(no metadata)"
echo "=== first/last bar ==="; head -1 "$S/datasets-out/market_raw/MES/1m/v001/data.jsonl" 2>/dev/null; tail -1 "$S/datasets-out/market_raw/MES/1m/v001/data.jsonl" 2>/dev/null
echo "=== live trader last 3 ==="; journalctl -u ict-trader-live.service -n 3 --no-pager 2>/dev/null | sed 's/.*python3\[[0-9]*\]: //' | tail -3
git -C "$LR" worktree remove --force "$S" 2>/dev/null
