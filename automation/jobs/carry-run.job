TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot || { echo "NO REPO"; exit 1; }
BR=claude/expansion-backtesting-research-y74054
git fetch -q origin "$BR" 2>&1 | tail -1 || true
git show "origin/$BR:scripts/backtest_funding_carry.py" > /tmp/bfc.py 2>/dev/null && echo "got harness" || { echo "MISSING harness"; exit 1; }
PY=""
for c in .venv/bin/python venv/bin/python $(find /home/ubuntu -maxdepth 5 -path '*/bin/python' 2>/dev/null); do
  if [ -x "$c" ] && "$c" -c "import pandas,numpy" 2>/dev/null; then PY="$c"; break; fi
done
[ -z "$PY" ] && { echo "no pandas python"; exit 0; }
echo "PY=$PY"

echo "########## FETCH alt funding history (Bybit) ##########"
for S in ETHUSDT SOLUSDT; do
  if [ ! -s "data/funding_${S}.csv" ]; then
    timeout 300 "$PY" scripts/ops/fetch_bybit_funding.py --symbol "$S" --days 1200 --output "data/funding_${S}.csv" 2>&1 | tail -4 || echo "fetch $S failed"
  fi
  echo "-- data/funding_${S}.csv:"; ls -la "data/funding_${S}.csv" 2>&1; head -2 "data/funding_${S}.csv" 2>/dev/null; tail -1 "data/funding_${S}.csv" 2>/dev/null
done

run_carry () {  # sym price_csv
  S="$1"; PX="$2"; FUND="data/funding_${S}.csv"
  [ -s "$FUND" ] || { echo "SKIP $S — no funding"; return; }
  [ -s "$PX" ]   || { echo "SKIP $S — no price $PX"; return; }
  echo ""
  echo "################# CARRY $S (price=$PX, 1h) #################"
  echo "-- directional --"
  timeout 600 "$PY" /tmp/bfc.py --data "$PX" --funding-data "$FUND" --symbol "$S" \
    --timeframe 1h --resample 1h --funding-window 3 --funding-lag-settlements 1 \
    --funding-threshold 0.0003 --funding-exit-threshold 0.0001 --max-hold-bars 72 2>&1 | tail -8
  echo "-- market-neutral --"
  timeout 600 "$PY" /tmp/bfc.py --data "$PX" --funding-data "$FUND" --symbol "$S" \
    --timeframe 1h --resample 1h --funding-window 3 --funding-lag-settlements 1 \
    --funding-threshold 0.0003 --funding-exit-threshold 0.0001 --max-hold-bars 72 --hedge neutral 2>&1 | tail -8
  echo "-- directional threshold sweep --"
  timeout 900 "$PY" /tmp/bfc.py --data "$PX" --funding-data "$FUND" --symbol "$S" \
    --timeframe 1h --resample 1h --funding-window 3 --funding-lag-settlements 1 \
    --funding-exit-threshold 0.0001 --max-hold-bars 72 \
    --funding-threshold-sweep '0.0001:0.0006:0.0001' 2>&1 | tail -40
  echo "-- market-neutral threshold sweep --"
  timeout 900 "$PY" /tmp/bfc.py --data "$PX" --funding-data "$FUND" --symbol "$S" \
    --timeframe 1h --resample 1h --funding-window 3 --funding-lag-settlements 1 \
    --funding-exit-threshold 0.0001 --max-hold-bars 72 --hedge neutral \
    --funding-threshold-sweep '0.0001:0.0006:0.0001' 2>&1 | tail -40
}

run_carry ETHUSDT data/ETHUSDT_15m.csv
run_carry SOLUSDT data/SOLUSDT_15m.csv
echo "== DONE =="
