TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot || { echo "NO REPO"; exit 1; }
BR=claude/expansion-backtesting-research-y74054
git fetch -q origin "$BR" 2>&1 | tail -1 || true
PY=""
for c in .venv/bin/python venv/bin/python $(find /home/ubuntu -maxdepth 5 -path '*/bin/python' 2>/dev/null); do
  if [ -x "$c" ] && "$c" -c "import pandas,numpy" 2>/dev/null; then PY="$c"; break; fi
done
[ -z "$PY" ] && { echo "no pandas python"; exit 0; }
echo "PY=$PY"
git show "origin/$BR:config/research/studies/etf_intraday_trend.yaml"    > /tmp/it_trend.tpl    || { echo "no trend tpl"; exit 1; }
git show "origin/$BR:config/research/studies/etf_intraday_pullback.yaml" > /tmp/it_pullback.tpl || { echo "no pullback tpl"; exit 1; }

for S in SPY QQQ GLD IWM SLV USO TLT IEF; do
  [ -s "data/${S}_1h.csv" ] || { echo "SKIP $S — no data/${S}_1h.csv"; continue; }
  for fam in trend pullback; do
    sed "s/SPY/${S}/g" /tmp/it_${fam}.tpl > /tmp/it_${fam}_${S}.yaml
    echo ""
    echo "######## intraday ${fam} ${S} (1h) ########"
    timeout 1800 "$PY" scripts/ops/research_sweep.py --study /tmp/it_${fam}_${S}.yaml --out /tmp/oit_${fam}_${S} 2>&1 | tail -10
  done
done
echo "== DONE =="

# re-trigger 2026-06-20T17:33:02Z
