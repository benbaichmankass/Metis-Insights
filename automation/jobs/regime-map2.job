TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot
git fetch origin main -q; git checkout -f main -q 2>/dev/null; git reset --hard origin/main -q
git fetch origin claude/system-audit-strategy-ml-srcwda -q
git checkout origin/claude/system-audit-strategy-ml-srcwda -- scripts/ops/regime_performance_map.py
source .venv/bin/activate 2>/dev/null || source venv/bin/activate 2>/dev/null || true
R=results/m15_regime_map; mkdir -p "$R"
run(){ local fam=$1 scr=$2 rs=$3 sym=$4 D="data/$4_15m.csv"; [ -f "$D" ] || return
  python3 "scripts/$scr" --data "$D" --resample "$rs" --timeframe "$rs" --symbol "$sym" --emit-trades "$R/${fam}_${sym}.jsonl" --json /dev/null >/dev/null 2>&1
  python3 scripts/ops/regime_performance_map.py --data "$D" --resample "$rs" --emit "$R/${fam}_${sym}.jsonl" --label "${fam}_${sym}_${rs}" --min-bucket 20 --json "$R/regmap_${fam}_${sym}.json" >/dev/null 2>&1; }
for SYM in ETHUSDT SOLUSDT XRPUSDT ADAUSDT AVAXUSDT; do run trend backtest_trend.py 4h "$SYM"; run pullback backtest_pullback.py 2h "$SYM"; done
echo "=== REGIME-CONDITIONAL EDGE per cell — favorable ADX regimes + concentration ==="
python3 - <<'PY'
import json,glob,os
rows=[]
for f in sorted(glob.glob("results/m15_regime_map/regmap_*.json")):
    d=json.load(open(f)); v=d.get("verdict",{}); ba=d.get("by_adx",{})
    prof="  ".join(f"{b}:{ba[b]['mean']:+.2f}({ba[b]['n']})" for b in ["<15","15-25","25-35",">35"] if b in ba)
    rows.append((d["label"], d["total_net_r"], v.get("favorable_adx_regimes"), v.get("best_band"), v.get("best_band_share_pct"), prof))
for lab,tot,fav,best,conc,prof in rows:
    print(f"{lab:24} total={tot:7.1f} | fav={str(fav):28} best={str(best):6} conc={conc}%")
    print(f"   ADX-mean-R: {prof}")
PY
echo "REGIME_MAP_DONE"
