TARGET=trainer
---
set -uo pipefail
BR=claude/ict-strategy-expansion-awpv8x
REPO=/home/ubuntu/ict-trading-bot
WT=/tmp/xa-abl
DATA=/tmp/xa-data       # reuse the datasets the pwf job built
echo "===== sync branch into a throwaway worktree ====="
cd "$REPO" || exit 2
git fetch origin "$BR" || exit 2
git worktree remove --force "$WT" 2>/dev/null || true
rm -rf "$WT"
git worktree add -f "$WT" "origin/$BR" || exit 2
cd "$WT" || exit 2
git log --oneline -1
# shellcheck disable=SC1091
source "$REPO/.venv/bin/activate"
export ICT_OFFVM_BUILD_HOST=1

OUT="$DATA/datasets-out"
REG="$WT/ml/registry-store"
EXP="$WT/ml/experiments-runs"
FEAT="$OUT/market_features/ETHUSDT/1h/v001/data.jsonl"
START="$(date -u -d '5 years ago' +%Y-%m-%d 2>/dev/null || echo 2021-01-01)"
END="$(date -u +%Y-%m-%d)"
if [ ! -f "$FEAT" ]; then
  echo "===== datasets missing — rebuilding into $DATA ====="
  python -c "import ccxt" 2>/dev/null || pip install --quiet "ccxt>=4.0" || true
  for S in ETHUSDT BTCUSDT SOLUSDT; do
    python -m ml build-dataset market_raw --output-dir "$OUT" --version v002 \
      --source bybit_v5_offvm --symbol-scope "$S" --timeframe 1h --overwrite \
      "adapter=bybit_v5_offvm" "symbol=$S" "timeframe=1h" "start=$START" "end=$END" || echo "WARN $S"
  done
  python -m scripts.ml.build_cross_asset \
    --target "$OUT/market_raw/ETHUSDT/1h/v002" \
    --peer "$OUT/market_raw/BTCUSDT/1h/v002" --peer "$OUT/market_raw/SOLUSDT/1h/v002" \
    --out "$OUT/cross_asset/ETHUSDT/1h/v001" || exit 1
  python -m ml build-dataset market_features --output-dir "$OUT" --version v001 \
    --source "$OUT/market_raw/ETHUSDT/1h/v002" --symbol-scope ETHUSDT --timeframe 1h \
    --overwrite "market_raw_path=$OUT/market_raw/ETHUSDT/1h/v002" \
    "cross_asset_path=$OUT/cross_asset/ETHUSDT/1h/v001" \
    "vol_window_n=20" "forward_window_m=5" "vol_threshold=0.005" \
    "trend_threshold=0.005" "n_vol_buckets=3" || exit 1
else
  echo "===== reusing datasets at $DATA ($(wc -l < "$FEAT") rows) ====="
fi

echo "===== generate ablation manifests (purged-WF-CV) ====="
python - <<'PY'
import yaml, pathlib, copy
base = yaml.safe_load(pathlib.Path("ml/configs/eth-regime-1h-lgbm-xasset-v1.yaml").read_text())
own = ["vol_bucket","rolling_log_return_vol","log_return","log_return_lag_1",
       "log_return_lag_2","hour_of_day","dayofweek"]
def xa(suf): return [f"xa_peer1_{suf}", f"xa_peer2_{suf}"]
full_xa = ["xa_peer1_ret","xa_peer1_ret_lag1","xa_peer1_vol","xa_peer1_rel_strength",
           "xa_peer1_beta","xa_peer1_beta_residual","xa_peer2_ret","xa_peer2_ret_lag1",
           "xa_peer2_vol","xa_peer2_rel_strength","xa_peer2_beta","xa_peer2_beta_residual",
           "xa_breadth_up"]
variants = {
  "full":          full_xa,
  "base":          [],
  "no_sol":        [c for c in full_xa if not c.startswith("xa_peer2_")],
  "no_btc":        [c for c in full_xa if not c.startswith("xa_peer1_")],
  "no_leadlag":    [c for c in full_xa if not c.endswith("_ret_lag1")],
  "no_relstr":     [c for c in full_xa if not c.endswith("_rel_strength")],
  "no_beta":       [c for c in full_xa if not (c.endswith("_beta") or c.endswith("_beta_residual"))],
  "comove_only":   xa("ret") + ["xa_breadth_up"],
  "leadlag_only":  xa("ret_lag1") + ["xa_breadth_up"],
}
for name, xacols in variants.items():
    m = copy.deepcopy(base)
    m["model_id"] = f"eth-xa-abl-{name}"
    m["trainer_config"]["feature_columns"] = own + xacols
    ec = m["evaluator_config"]; ec.pop("holdout_fraction", None)
    ec["split_strategy"]="purged_walk_forward"; ec["time_column"]="ts"
    ec["n_folds"]=5; ec["min_train_fraction"]=0.5; ec["embargo_n"]=10
    pathlib.Path("ml/configs", f"eth-xa-abl-{name}.yaml").write_text(yaml.safe_dump(m, sort_keys=False))
    print("wrote", name, "xa_cols=", len(xacols))
PY

echo "===== train all ablation variants ====="
for name in full base no_sol no_btc no_leadlag no_relstr no_beta comove_only leadlag_only; do
  echo "--- train eth-xa-abl-$name ---"
  python -m ml train "ml/configs/eth-xa-abl-$name.yaml" \
    --datasets-root "$OUT" --registry-root "$REG" --experiments-root "$EXP" \
    --commit-sha "$(git rev-parse --short HEAD)" 2>/dev/null | \
    python -c "import sys,json; d=json.load(sys.stdin); m=d['metrics']; print('%-13s wf=%.4f f1_range=%.4f recall_range=%.4f f1_vol=%.4f acc=%.4f' % ('$name', m['weighted_f1'], m['f1_range'], m['recall_range'], m['f1_volatile'], m['accuracy']))" || echo "WARN $name"
done
echo "===== done (delta vs base/full computed on landing) ====="
