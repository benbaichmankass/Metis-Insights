TARGET=trainer
---
set -uo pipefail
cd /home/ubuntu/ict-trading-bot || { echo "NO REPO"; exit 1; }
BR=claude/expansion-backtesting-research-y74054
git fetch -q origin "$BR" 2>&1 | tail -1 || true
PY=""
for c in .venv/bin/python venv/bin/python $(find /home/ubuntu -maxdepth 5 -path '*/bin/python' 2>/dev/null); do
  if [ -x "$c" ] && "$c" -c "import pandas,numpy" 2>/dev/null; then PY="$c"; break; fi
done
[ -z "$PY" ] && { echo "no pandas python"; exit 0; }
echo "PY=$PY"

echo "== (a) pairs harness self-test (synthetic OU spread) =="
git show "origin/$BR:scripts/backtest_pairs.py" > /tmp/backtest_pairs.py
"$PY" /tmp/backtest_pairs.py --self-test 2>&1 | tail -4

echo ""
echo "== (b) fetch Dukascopy 1h RTH for the intraday-covered ETFs =="
declare -A MAP=(
  [SPY]=INSTRUMENT_ETF_CFD_US_SPY_US_USD
  [QQQ]=INSTRUMENT_ETF_CFD_US_QQQ_US_USD
  [GLD]=INSTRUMENT_ETF_CFD_US_GLD_US_USD
  [IWM]=INSTRUMENT_ETF_CFD_US_IWM_US_USD
  [SLV]=INSTRUMENT_ETF_CFD_US_SLV_US_USD
  [USO]=INSTRUMENT_ETF_CFD_US_USO_US_USD
  [TLT]=INSTRUMENT_ETF_CFD_US_TLT_US_USD
  [IEF]=INSTRUMENT_ETF_CFD_US_IEF_US_USD
)
for S in SPY QQQ GLD IWM SLV USO TLT IEF; do
  OUT="data/${S}_1h.csv"
  "$PY" scripts/ops/fetch_dukascopy_ohlcv.py --instrument "${MAP[$S]}" \
      --interval 1h --start 2012-01-01 --rth-only --output "$OUT" >/dev/null 2>&1 || { echo "$S: FETCH FAIL"; continue; }
  if [ -s "$OUT" ]; then
    rows=$(wc -l < "$OUT")
    rng=$("$PY" - "$OUT" <<'PYEOF'
import sys, pandas as pd
df = pd.read_csv(sys.argv[1])
tc = [c for c in df.columns if c.lower()=="timestamp"][0]
print(f"{df[tc].iloc[0]} -> {df[tc].iloc[-1]}")
PYEOF
)
    echo "$S: $rows rows  $rng"
  else
    echo "$S: EMPTY"
  fi
done
echo "== DONE =="
