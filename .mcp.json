{
  "mcpServers": {
    "github-actions": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server",
        "--toolsets=all"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GHPAT}"
      }
    }
  }
}
