# ============================================
# ICT CLAUDE BRIDGE SYSTEMD SERVICE
# Telegram <-> Claude (Anthropic API) bridge
# Save to: /etc/systemd/system/ict-claude-bridge.service
# ============================================

[Unit]
Description=ICT Trading Bot - Claude Telegram Bridge
After=network.target
Wants=network-online.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/ict-trading-bot
ExecStart=/usr/bin/python3 -u -B -m src.bot.claude_bridge
Restart=always
RestartSec=15
StandardOutput=append:/home/ubuntu/ict-trading-bot/runtime_logs/claude_bridge.log
StandardError=append:/home/ubuntu/ict-trading-bot/runtime_logs/claude_bridge_error.log
EnvironmentFile=/home/ubuntu/ict-trading-bot/.env

# Memory cap so a runaway bridge can't OOM the trader
MemoryMax=200M
MemoryHigh=150M

[Install]
WantedBy=multi-user.target
