# ============================================
# ICT GIT SYNC SYSTEMD TIMER
# Triggers ict-git-sync.service every 5 minutes
# Save to: /etc/systemd/system/ict-git-sync.timer
# ============================================

[Unit]
Description=Trigger ict-git-sync every 5 minutes
Requires=ict-git-sync.service

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min
RandomizedDelaySec=30
Persistent=true
Unit=ict-git-sync.service

[Install]
WantedBy=timers.target
