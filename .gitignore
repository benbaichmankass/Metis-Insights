# Secrets
.env
.env.*
!.env.example
master-secrets.yaml
*master-secrets*.yaml
age-keys.txt
*.agekey

# Allow the placeholder template only
!config/master-secrets.template.yaml

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# Runtime / process
*.pid
*.log
logs/
runtime_logs/
# Velotrade phase-2b: persistent prop-state — per-account counters
# (cumulative_pnl_pct, active_days, entry_date) survive trader
# restarts. Gitignored so secrets-adjacent data stays off git.
runtime_state/

# Databases
*.db
*.sqlite
*.sqlite3
# SQLite WAL/SHM sidecars (created transiently when a test/process opens a DB)
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# Backup / temp
*.bak
*.tmp
*.temp
*.save
*~

# Generated outputs
output/
reports/
*.html
# But: vendored web templates are tracked (recursively).
!web/templates/**/*.html
!web/templates/*.html
# And: the consolidated /system-report subsystem is tracked despite the broad
# `reports/` + `*.html` ignores above — the renderer/docs are code, and the
# generated reports under comms/reports/ are COMMITTED artifacts (stable GitHub
# links + the VM's ict-git-sync mirrors them for /api/bot/reports). The dir
# re-includes must precede the recursive `**` re-includes (you can't re-include
# a file whose parent dir is still excluded).
!scripts/reports/
!scripts/reports/**
!docs/reports/
!docs/reports/**
!comms/reports/
!comms/reports/**

# Data files (large/generated CSVs ignored; manifests and placeholders tracked)
data/*.csv
!data/ict_validate_manifest.csv
data/ohlcv/*.csv
data/backtests/sprint-015/*.csv
data/backtests/sprint-015/*.parquet

# Telegram ping queue (drained by VM-side notify-on-pull script)
docs/claude/pending-pings.jsonl
!docs/claude/pending-pings.jsonl.template

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build / packaging
build/
dist/
*.egg-info/
# Claude/local tooling
.claude/settings.local.json
# Transient git worktrees created by Claude Code background agents
.claude/worktrees/
# Notebook checkpoints
.ipynb_checkpoints/
# Python/tooling caches
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
# ML/data artifacts — store large assets in Drive/Hugging Face
*.pt
*.pth
*.ckpt
*.safetensors
ml/data/raw/
ml/data/processed/
ml/models/checkpoints/

# Training experiments — keep PLAN.md, RECOMMENDATIONS.md, and results/
# (text/metrics/plots), ignore raw datasets and large intermediate
# artifacts. See docs/claude/training-improvement-workflow.md.
# Pattern: re-include directories first so git recurses into them, then
# allow specific text files; finally re-ignore large binary formats
# inside results/.
experiments/**/*
!experiments/**/
!experiments/**/PLAN.md
!experiments/**/RECOMMENDATIONS.md
!experiments/**/SUMMARY.md
!experiments/**/*.py
!experiments/**/results/**/*.json
!experiments/**/results/**/*.md
!experiments/**/results/**/*.png
!experiments/**/results/**/*.svg
!experiments/**/results/**/*.txt

# Recombination sweep outputs (research-only artifacts; regenerated per run).
# See scripts/ops/recombination_sweep.py + docs/research/strategy-primitives-recombination-DESIGN.md.
results/recombination/

# Don't track bytecode under the re-included reports dirs
scripts/reports/__pycache__/

# M28 backtest candles — regenerated per run by scripts/macro/fetch_macro_candles.py (not committed)
data/macro_candles/
