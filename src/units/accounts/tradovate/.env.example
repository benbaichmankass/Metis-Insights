# Tradovate integration — environment template.
# Copy to `.env.tradovate` (or load via systemd EnvironmentFile=) and
# fill in the values for the environment you're using. Demo is the
# default; do NOT set TRADOVATE_ENV=live until you have a funded live
# account + the API Access add-on enabled on your Tradovate account.

# --- Environment toggle (demo is default) ---
TRADOVATE_ENV=demo

# --- Credentials (required) ---
TRADOVATE_USERNAME=your-demo-username
TRADOVATE_PASSWORD=your-demo-password
TRADOVATE_APP_ID=your-app-name
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your-cid
TRADOVATE_SECRET=your-app-secret
TRADOVATE_DEVICE_ID=ict-bot-linux-01

# --- Runtime safety (defaults are safe) ---
# Dry-run short-circuits order placement and returns a synthetic Order.
# Leave this on while wiring up the integration; flip to false to send
# real orders in demo (still safe — demo is paper money).
TRADOVATE_DRY_RUN=true

# Comma-separated whitelist (empty = allow anything). Recommend pinning
# this even in demo so a typo can't route an order to the wrong symbol.
TRADOVATE_ALLOWED_SYMBOLS=MESM6,MNQM6

TRADOVATE_MAX_POS_PER_SYMBOL=1
TRADOVATE_MAX_OPEN_ORDERS=5
TRADOVATE_REQUEST_TIMEOUT_S=15

# --- Smoke-test override ---
# Set to true ONLY if you explicitly want the smoke test to place a
# 1-lot order on the configured simulation account.
ENABLE_ORDER_TEST=false
