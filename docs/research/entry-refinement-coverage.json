  "vol_at_entry": "skip entries at extreme entry-bar ATR percentile (E-2)",
  "time_of_day": "skip the leg's data-derived net-negative hours; same yearly walk-forward gate - no cherry-picked windows (E-2)",
  "p_win_head": "ML P(win)-at-entry head (first_touch +1R before -1R label); primary consumer is the M18 allocator (E-3)"
 },
